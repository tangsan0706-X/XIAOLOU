# 8080 备用端口：ISP 封 80 时外网可通过此端口访问（非标准端口一般不封）
:8080 {
	handle /jaaz* {
		reverse_proxy localhost:4100
	}

	handle /jaaz-api* {
		reverse_proxy localhost:4100
	}

	handle /socket.io/* {
		reverse_proxy localhost:4100
	}

	handle /api/* {
		reverse_proxy localhost:4100
	}

	handle /uploads/* {
		reverse_proxy localhost:4100
	}

	handle {
		reverse_proxy localhost:3000
	}
}

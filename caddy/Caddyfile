# ============================================================
# 小楼 AI — Caddy 反向代理配置
# 自动申请并续期 Let's Encrypt TLS 证书（需要 80/443 可公网访问）
# ============================================================

# HTTPS 域名入口：Caddy 自动向 Let's Encrypt 申请证书
www.xiaolouai.cn {
	handle /jaaz* {
		reverse_proxy localhost:4100
	}

	handle /jaaz-api* {
		reverse_proxy localhost:4100
	}

	handle /socket.io/* {
		reverse_proxy localhost:4100
	}

	handle /api/* {
		reverse_proxy localhost:4100
	}

	handle /uploads/* {
		reverse_proxy localhost:4100
	}

	handle {
		reverse_proxy localhost:3000
	}

	log {
		output file D:/xuan/小楼WEB/caddy/logs/access.log {
			roll_size 50mb
			roll_keep 5
		}
	}
}

# HTTP 80 端口入口：公网 IP 直连 / 证书申请期间兜底 / IP 调试用
# Xiaolou official domain, HTTP first.
http://www.xiaolou.cn, http://xiaolou.cn {
	handle /jaaz* {
		reverse_proxy localhost:4100
	}

	handle /jaaz-api* {
		reverse_proxy localhost:4100
	}

	handle /socket.io/* {
		reverse_proxy localhost:4100
	}

	handle /api/* {
		reverse_proxy localhost:4100
	}

	handle /uploads/* {
		reverse_proxy localhost:4100
	}

	handle {
		reverse_proxy localhost:3000
	}

	log {
		output file D:/xuan/小楼WEB/caddy/logs/xiaolou-cn-access.log {
			roll_size 50mb
			roll_keep 5
		}
	}
}

